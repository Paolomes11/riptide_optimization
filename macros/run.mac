# Particle source: optical photons
/gps/particle opticalphoton
/gps/energy 2.5 eV

/gps/pos/type Plane
#/gps/pos/shape Square
/gps/pos/centre 0 10 0 mm
/gps/pos/rot1 0 1 0
/gps/pos/rot2 0 0 1
#/gps/pos/halfx 0.05 mm
#/gps/pos/halfy 0.05 mm

# Direzione principale lungo +X con piccola divergenza
/gps/ang/type iso
/gps/direction 1 0 0

# Run
/run/beamOn 1000
#/run/beamOn 1