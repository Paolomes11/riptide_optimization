# Particle source: optical photons
/gps/particle opticalphoton
/gps/energy 2.5 eV

/gps/pos/type Plane
/gps/pos/shape Annulus
/gps/pos/centre 0 0 0 cm
/gps/pos/rot1 0 1 0
/gps/pos/rot2 0 0 2
/gps/pos/radius 10 mm
/gps/pos/inner_radius 0 mm


# Direzione principale lungo +X
/gps/ang/type iso
/gps/direction 1 0 0

# Run
/run/beamOn 10000