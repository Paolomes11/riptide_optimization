# Particle source: optical photons (sferetta isotropa verso detector)
/gps/particle opticalphoton
/gps/energy 2.5 eV

# Sorgente: piccola sferetta
/gps/pos/type Volume
/gps/pos/shape Sphere
/gps/pos/radius 0.1 mm

# Emissione: isotropa verso il detector (+X)
/gps/ang/type iso
/gps/ang/rot1 0 -1 0
/gps/ang/rot2 0 0 1
/gps/ang/mintheta 0 deg
/gps/ang/maxtheta 90 deg

# Run
/run/beamOn 1000